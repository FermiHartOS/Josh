#include <shell.h>
#include <vga.h>
#include <keyboard.h>

#define MAX_CMD_LEN 128
#define HISTORY_SIZE 10

static char cmd_buffer[MAX_CMD_LEN];
static int cmd_idx = 0;

// HistГіrico de comandos
static char history[HISTORY_SIZE][MAX_CMD_LEN];
static int history_idx = 0;
static int current_history_pos = -1;

int str_compare(const char* s1, const char* s2) {
    while (*s1 && (*s1 == *s2)) { s1++; s2++; }
    return *(unsigned char*)s1 - *(unsigned char*)s2;
}

void str_copy(char* dest, const char* src) {
    int i = 0;
    while (src[i] != '\0') {
        dest[i] = src[i];
        i++;
    }
    dest[i] = '\0';
}

void print_prompt() {
    vga_put_string("\nFermi@root: ", COLOR_LIGHT_CYAN);
}

void save_to_history(const char* cmd) {
    if (cmd[0] == '\0') return;
    if (history_idx > 0) {
        int last = (history_idx - 1 + HISTORY_SIZE) % HISTORY_SIZE;
        if (str_compare(history[last], cmd) == 0) return;
    }
    str_copy(history[history_idx], cmd);
    history_idx = (history_idx + 1) % HISTORY_SIZE;
    current_history_pos = history_idx;
}

void cmd_fetch() {
    vga_put_string("\n  ######   Fermi Hart OS v1.2", COLOR_LIGHT_CYAN);
    vga_put_string("\n  ######   Kernel: x86_32 Monolithic", COLOR_WHITE);
    vga_put_string("\n  ######   Shell: MiniBash Pro (Reactive)", COLOR_WHITE);
    vga_put_string("\n  ######   Uptime: Just booted", COLOR_WHITE);
    vga_put_char('\n', COLOR_WHITE);
}

void execute_command() {
    cmd_buffer[cmd_idx] = '\0';
    save_to_history(cmd_buffer);
    current_history_pos = -1;

    vga_put_char('\n', COLOR_WHITE);

    if (str_compare(cmd_buffer, "help") == 0) {
        vga_put_string("COMMANDS: help, clear, fetch, ver, panic, halt, up, down", COLOR_YELLOW);
    } 
    else if (str_compare(cmd_buffer, "clear") == 0) {
        vga_clear();
    } 
    else if (str_compare(cmd_buffer, "fetch") == 0) {
        cmd_fetch();
    }
    else if (str_compare(cmd_buffer, "ver") == 0) {
        vga_put_string("Fermi Hart OS [Version 1.2.54-Pro]", COLOR_WHITE);
    }
    else if (str_compare(cmd_buffer, "panic") == 0) {
        vga_clear();
        vga_put_string("KERNEL PANIC: User triggered panic test.", COLOR_LIGHT_RED);
        asm volatile("cli; hlt");
    }
    else if (str_compare(cmd_buffer, "halt") == 0) {
        vga_put_string("Powering down...", COLOR_WHITE);
        asm volatile("hlt");
    }
    else if (cmd_idx > 0) {
        vga_put_string("MiniBash: '", COLOR_WHITE);
        vga_put_string(cmd_buffer, COLOR_LIGHT_RED);
        vga_put_string("' not found.\n", COLOR_WHITE);
    }

    for(int i=0; i<MAX_CMD_LEN; i++) cmd_buffer[i] = 0;
    cmd_idx = 0;
    
    print_prompt();
}

// FunГ§ГЈo auxiliar para converter hex para string de debug
static void print_hex_debug(uint8_t val) {
    char hex_chars[] = "0123456789ABCDEF";
    vga_put_string(" [0x", COLOR_DARK_GREY);
    vga_put_char(hex_chars[(val >> 4) & 0xF], COLOR_DARK_GREY);
    vga_put_char(hex_chars[val & 0xF], COLOR_DARK_GREY);
    vga_put_char(']', COLOR_DARK_GREY);
}

void start_shell() {
    vga_clear();
    vga_put_string("Welcome to ", COLOR_WHITE);
    vga_put_string("Fermi Hart OS Pro\n", COLOR_LIGHT_CYAN);
    vga_put_string("Type 'help' for available tools.\n", COLOR_DARK_GREY);
    vga_put_string("System is in POLLING MODE (IDT Disabled).\n", COLOR_RED);
    vga_put_string("Debug: Teclas mostrarГЈo [0xXX].\n", COLOR_DARK_GREY);
    print_prompt();
    
    while(1) {
        uint8_t scancode = 0;
        char c = 0;

        // --- POLLING DIRETO NO HARDWARE (Fallback Robusto) ---
        // LГӘ status da porta 0x64
        uint8_t status;
        asm volatile("inb $0x64, %0" : "=a"(status));
        
        // Se bit 0 estiver setado, hГЎ dado na porta 0x60
        if (status & 1) {
            asm volatile("inb $0x60, %0" : "=a"(scancode));
            
            // Ignora key release (bit 7 set)
            if (scancode & 0x80) continue;

            // Converte para caractere
            c = keycode_to_char(scancode);
            
            // DEBUG: Mostra o cГіdigo bruto da tecla
            print_hex_debug(scancode);
        } else {
            // Sem tecla, continua o loop sem travar
            continue;
        }

        // Se a conversГЈo falhou (tecla especial nГЈo mapeada), ignora
        if (c == 0) continue;

        if (c == '\n') {
            execute_command();
        } else if (c == '\b') {
            if (cmd_idx > 0) {
                cmd_idx--;
                vga_put_char('\b', COLOR_WHITE); // Apaga visualmente
            }
        } else if (cmd_idx < MAX_CMD_LEN - 1) {
            cmd_buffer[cmd_idx++] = c;
            vga_put_char(c, COLOR_WHITE); // Eco imediato
        }
    }
}
