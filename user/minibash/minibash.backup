/**
 * @file user/minibash/minibash.c
 * @brief MiniBash Pro v2 — Shell Reativo do jOSh OS
 *
 * Layout da tela (80x25):
 *   Linhas 0-22:  área de conteúdo (scroll protegido)
 *   Linha 23:     separador fino (thin line CP437)
 *   Linha 24:     status bar minimalista (fundo preto, cores cyan)
 */

#include <shell.h>
#include <vga.h>
#include <keyboard.h>
#include <timer.h>
#include <stdint.h>
#include <nosound.h>

/* ── Identidade do sistema (uname fields) ─────────────────────── */
#define OS_SYSNAME    "jOSh"
#define OS_NODENAME   "fermihart"
#define OS_RELEASE    "1.3.0-reactive"
#define OS_VERSION    "#1 Mon Mar 30 2026"
#define OS_MACHINE    "i686"
#define OS_PROCESSOR  "x86_32"
#define OS_PLATFORM   "bare-metal"

#define SHELL_USER    "fermi"
#define SHELL_CWD     "/"

/* ── Shell config ─────────────────────────────────────────────── */
#define MAX_CMD_LEN   128
#define HISTORY_SIZE  16

/* ── Estado ───────────────────────────────────────────────────── */
static char cmd_buffer[MAX_CMD_LEN];
static int  cmd_idx = 0;

static char history[HISTORY_SIZE][MAX_CMD_LEN];
static int  history_count  = 0;
static int  history_write  = 0;
static int  history_browse = -1;

static uint32_t cmd_count = 0;

/* ══════════════════════════════════════════════════════════════════
 *  Tabela de comandos — usada pelo Tab Completion e Help dinâmico
 * ══════════════════════════════════════════════════════════════════ */
static const char* const cmd_table[] = {
    "about",
    "beep",
    "clear",
    "colors",
    "date",
    "echo",
    "env",
    "fetch",
    "halt",
    "help",
    "history",
    "hostname",
    "mem",
    "panic",
    "play",
    "reboot",
    "starwars",
    "uname",
    "uptime",
    "ver",
    "whoami",
};
#define CMD_TABLE_SIZE (sizeof(cmd_table) / sizeof(cmd_table[0]))

/* ══════════════════════════════════════════════════════════════════
 *  String utilities
 * ══════════════════════════════════════════════════════════════════ */
static int str_compare(const char* s1, const char* s2) {
    while (*s1 && (*s1 == *s2)) { s1++; s2++; }
    return *(const unsigned char*)s1 - *(const unsigned char*)s2;
}

static int str_starts_with(const char* str, const char* prefix) {
    while (*prefix) {
        if (*str != *prefix) return 0;
        str++; prefix++;
    }
    return 1;
}

static int str_len(const char* s) {
    int n = 0; while (s[n]) n++; return n;
}

static void str_copy(char* dest, const char* src) {
    int i = 0; while (src[i]) { dest[i] = src[i]; i++; } dest[i] = '\0';
}

static void itoa(uint32_t val, char* buf) {
    char tmp[12]; int i = 0;
    if (val == 0) { buf[0] = '0'; buf[1] = '\0'; return; }
    while (val > 0) { tmp[i++] = '0' + (val % 10); val /= 10; }
    int j = 0; while (i > 0) buf[j++] = tmp[--i]; buf[j] = '\0';
}

static void itoa_pad2(uint32_t val, char* buf) {
    buf[0] = '0' + (val / 10) % 10;
    buf[1] = '0' + val % 10;
    buf[2] = '\0';
}

static void itoa_hex(uint32_t val, char* buf) {
    const char hex[] = "0123456789ABCDEF";
    buf[0] = '0'; buf[1] = 'x';
    for (int i = 7; i >= 0; i--)
        buf[2 + (7 - i)] = hex[(val >> (i * 4)) & 0xF];
    buf[10] = '\0';
}

/* ══════════════════════════════════════════════════════════════════
 *  Status bar (linha 23 = separador, linha 24 = info)
 * ══════════════════════════════════════════════════════════════════ */
static void draw_status_bar(void) {
    char buf[12];

    /* Linha 23: separador fino */
    for (int x = 0; x < 80; x++)
        vga_put_at(x, 23, 0xC4, COLOR_DARK_GREY); /* ─ thin horizontal */

    /* Linha 24: limpa com fundo preto */
    vga_fill_row(24, ' ', COLOR_DARK_GREY);

    int pos = 1;

    /* Relógio */
    uint32_t h, m, s;
    timer_get_clock(&h, &m, &s);
    itoa_pad2(h, buf);
    vga_put_string_at(pos, 24, buf, COLOR_LIGHT_CYAN); pos += 2;
    vga_put_at(pos, 24, ':', COLOR_DARK_GREY); pos += 1;
    itoa_pad2(m, buf);
    vga_put_string_at(pos, 24, buf, COLOR_LIGHT_CYAN); pos += 2;
    vga_put_at(pos, 24, ':', COLOR_DARK_GREY); pos += 1;
    itoa_pad2(s, buf);
    vga_put_string_at(pos, 24, buf, COLOR_LIGHT_CYAN); pos += 2;

    /* Separador */
    pos += 1;
    vga_put_at(pos, 24, 0xB3, COLOR_DARK_GREY); pos += 2; /* │ */

    /* Uptime compacto */
    vga_put_string_at(pos, 24, "Up ", COLOR_DARK_GREY); pos += 3;
    itoa(timer_get_uptime_hours(), buf);
    vga_put_string_at(pos, 24, buf, COLOR_CYAN);
    pos += str_len(buf);
    vga_put_at(pos, 24, 'h', COLOR_DARK_GREY); pos += 1;
    itoa_pad2(timer_get_uptime_minutes(), buf);
    vga_put_string_at(pos, 24, buf, COLOR_CYAN); pos += 2;
    vga_put_at(pos, 24, 'm', COLOR_DARK_GREY); pos += 1;
    itoa_pad2(timer_get_uptime_seconds(), buf);
    vga_put_string_at(pos, 24, buf, COLOR_CYAN); pos += 2;
    vga_put_at(pos, 24, 's', COLOR_DARK_GREY); pos += 1;

    /* Separador */
    pos += 1;
    vga_put_at(pos, 24, 0xB3, COLOR_DARK_GREY); pos += 2;

    /* Cmds */
    vga_put_string_at(pos, 24, "Cmds:", COLOR_DARK_GREY); pos += 5;
    itoa(cmd_count, buf);
    vga_put_string_at(pos, 24, buf, COLOR_CYAN); pos += str_len(buf);

    /* Separador */
    pos += 1;
    vga_put_at(pos, 24, 0xB3, COLOR_DARK_GREY); pos += 2;

    /* PID (preparado para multitask — por enquanto sempre 0) */
    vga_put_string_at(pos, 24, "PID:", COLOR_DARK_GREY); pos += 4;
    vga_put_string_at(pos, 24, "0", COLOR_CYAN); pos += 1;

    /* Branding no canto direito */
    vga_put_string_at(74, 24, "jOSh", COLOR_LIGHT_CYAN);
    vga_put_at(78, 24, 0xEC, COLOR_LIGHT_MAGENTA); /* ∞ */
}

/* ══════════════════════════════════════════════════════════════════
 *  Prompt: fermi@fermihart:/∞ 
 * ══════════════════════════════════════════════════════════════════ */

/* Macro para imprimir o prompt — usado em print_prompt e tab_complete */
#define PRINT_PROMPT_INLINE() do { \
    vga_put_string(SHELL_USER, COLOR_LIGHT_GREEN); \
    vga_put_char('@', COLOR_DARK_GREY); \
    vga_put_string(OS_NODENAME, COLOR_LIGHT_GREEN); \
    vga_put_char(':', COLOR_DARK_GREY); \
    vga_put_string(SHELL_CWD, COLOR_LIGHT_BLUE); \
    vga_put_char((char)0xEC, COLOR_LIGHT_MAGENTA); \
    vga_put_char(' ', COLOR_WHITE); \
} while(0)

static void print_prompt(void) {
    draw_status_bar();
    vga_put_char('\n', COLOR_WHITE);
    PRINT_PROMPT_INLINE();
}

/* ══════════════════════════════════════════════════════════════════
 *  Line editing + History
 * ══════════════════════════════════════════════════════════════════ */
static void erase_input_line(void) {
    while (cmd_idx > 0) { vga_put_char('\b', COLOR_WHITE); cmd_idx--; }
}

static void replace_line(const char* new_text) {
    erase_input_line();
    str_copy(cmd_buffer, new_text);
    cmd_idx = str_len(cmd_buffer);
    vga_put_string(cmd_buffer, COLOR_WHITE);
}

/* ══════════════════════════════════════════════════════════════════
 *  Tab Completion
 *
 *  Comportamento:
 *    - Se cmd_buffer está vazio: lista todos os comandos
 *    - Se há exatamente 1 match: completa + adiciona espaço
 *    - Se há múltiplos matches: mostra todos, mantém o que já digitou
 *    - Se não há match: não faz nada
 * ══════════════════════════════════════════════════════════════════ */
static void tab_complete(void) {
    cmd_buffer[cmd_idx] = '\0';

    /* Conta matches */
    int match_count = 0;
    int last_match  = -1;

    for (int i = 0; i < (int)CMD_TABLE_SIZE; i++) {
        if (cmd_idx == 0 || str_starts_with(cmd_table[i], cmd_buffer)) {
            match_count++;
            last_match = i;
        }
    }

    if (match_count == 0) {
        /* Nenhum match — não faz nada */
        return;
    }

    if (match_count == 1) {
        /* Match único — completa o comando e adiciona espaço */
        replace_line(cmd_table[last_match]);
        /* Adiciona espaço se o comando aceita argumentos */
        if (cmd_idx < MAX_CMD_LEN - 2) {
            cmd_buffer[cmd_idx++] = ' ';
            cmd_buffer[cmd_idx] = '\0';
            vga_put_char(' ', COLOR_WHITE);
        }
        return;
    }

    /* Múltiplos matches — mostra todos abaixo e mantém a linha */
    vga_put_char('\n', COLOR_WHITE);
    vga_put_string("  ", COLOR_WHITE);

    int col = 0;
    for (int i = 0; i < (int)CMD_TABLE_SIZE; i++) {
        if (cmd_idx == 0 || str_starts_with(cmd_table[i], cmd_buffer)) {
            vga_put_string(cmd_table[i], COLOR_LIGHT_CYAN);
            vga_put_string("  ", COLOR_WHITE);
            col++;
            /* Quebra linha a cada 6 comandos para não ultrapassar 80 cols */
            if (col % 6 == 0) {
                vga_put_string("\n  ", COLOR_WHITE);
            }
        }
    }
    vga_put_char('\n', COLOR_WHITE);

    /* Reimprimi o prompt com o que já foi digitado */
    PRINT_PROMPT_INLINE();
    vga_put_string(cmd_buffer, COLOR_WHITE);
}

static void save_to_history(const char* cmd) {
    if (cmd[0] == '\0') return;
    if (history_count > 0) {
        int last = (history_write - 1 + HISTORY_SIZE) % HISTORY_SIZE;
        if (str_compare(history[last], cmd) == 0) return;
    }
    str_copy(history[history_write], cmd);
    history_write = (history_write + 1) % HISTORY_SIZE;
    if (history_count < HISTORY_SIZE) history_count++;
}

static void history_up(void) {
    if (history_count == 0) return;
    if (history_browse == -1) {
        history_browse = (history_write - 1 + HISTORY_SIZE) % HISTORY_SIZE;
    } else {
        int prev = (history_browse - 1 + HISTORY_SIZE) % HISTORY_SIZE;
        int oldest = (history_count < HISTORY_SIZE) ? 0 : history_write;
        if (prev == oldest && history_count == HISTORY_SIZE) return;
        if (history_browse == oldest) return;
        history_browse = prev;
    }
    replace_line(history[history_browse]);
}

static void history_down(void) {
    if (history_browse == -1) return;
    int most_recent = (history_write - 1 + HISTORY_SIZE) % HISTORY_SIZE;
    if (history_browse == most_recent) {
        history_browse = -1; erase_input_line(); cmd_buffer[0] = '\0'; return;
    }
    history_browse = (history_browse + 1) % HISTORY_SIZE;
    replace_line(history[history_browse]);
}

/* ══════════════════════════════════════════════════════════════════
 *  Commands
 * ══════════════════════════════════════════════════════════════════ */
static void cmd_uname(const char* args) {
    int show_all = 0, show_s = 0, show_n = 0, show_r = 0;
    int show_v = 0, show_m = 0, show_p = 0, show_i = 0;

    if (str_compare(args, "uname") == 0) { show_s = 1; }
    else if (str_starts_with(args, "uname ")) {
        const char* f = args + 6;
        while (*f) {
            if (*f == '-') { f++; continue; }
            if (*f == 'a') show_all = 1;
            if (*f == 's') show_s = 1;
            if (*f == 'n') show_n = 1;
            if (*f == 'r') show_r = 1;
            if (*f == 'v') show_v = 1;
            if (*f == 'm') show_m = 1;
            if (*f == 'p') show_p = 1;
            if (*f == 'i') show_i = 1;
            f++;
        }
    }

    if (show_all) {
        vga_put_string("  ", COLOR_WHITE);
        vga_put_string(OS_SYSNAME, COLOR_LIGHT_CYAN);    vga_put_char(' ', COLOR_WHITE);
        vga_put_string(OS_NODENAME, COLOR_LIGHT_GREEN);   vga_put_char(' ', COLOR_WHITE);
        vga_put_string(OS_RELEASE, COLOR_WHITE);           vga_put_char(' ', COLOR_WHITE);
        vga_put_string(OS_VERSION, COLOR_DARK_GREY);       vga_put_char(' ', COLOR_WHITE);
        vga_put_string(OS_MACHINE, COLOR_YELLOW);          vga_put_char(' ', COLOR_WHITE);
        vga_put_string(OS_PROCESSOR, COLOR_YELLOW);        vga_put_char(' ', COLOR_WHITE);
        vga_put_string(OS_PLATFORM, COLOR_DARK_GREY);
        vga_put_char('\n', COLOR_WHITE);
        return;
    }
    vga_put_string("  ", COLOR_WHITE);
    if (show_s) { vga_put_string(OS_SYSNAME, COLOR_LIGHT_CYAN);  vga_put_char(' ', COLOR_WHITE); }
    if (show_n) { vga_put_string(OS_NODENAME, COLOR_LIGHT_GREEN); vga_put_char(' ', COLOR_WHITE); }
    if (show_r) { vga_put_string(OS_RELEASE, COLOR_WHITE);        vga_put_char(' ', COLOR_WHITE); }
    if (show_v) { vga_put_string(OS_VERSION, COLOR_DARK_GREY);    vga_put_char(' ', COLOR_WHITE); }
    if (show_m) { vga_put_string(OS_MACHINE, COLOR_YELLOW);       vga_put_char(' ', COLOR_WHITE); }
    if (show_p) { vga_put_string(OS_PROCESSOR, COLOR_YELLOW);     vga_put_char(' ', COLOR_WHITE); }
    if (show_i) { vga_put_string(OS_PLATFORM, COLOR_DARK_GREY);   vga_put_char(' ', COLOR_WHITE); }
    vga_put_char('\n', COLOR_WHITE);
}

